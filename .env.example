# Anthropic API key for AI triage (optional — client-side triage works without it)
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps — required for /maps
# 1. Go to https://console.cloud.google.com/google/maps-apis
# 2. Create a project and enable "Maps JavaScript API"
# 3. Enable billing (required even for free usage)
# 4. APIs & Services → Credentials → Create API key
# 5. Paste your REAL key below (must start with AIza — not a placeholder)
# 6. Save this file as UTF-8, then restart: npm run dev
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# PostgreSQL (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/patadactari
