# Copy to .env.local — save as UTF-8 (Notepad: Save As → Encoding: UTF-8)

# AI triage chat (OpenAI — recommended)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# AI triage fallback (optional — only used if OPENAI fails or is not set)
# Use a key from https://aistudio.google.com/apikey (Generative Language API)
# Do NOT reuse your Google Maps key here.
# GEMINI_API_KEY=your_gemini_api_key_here

# Facilities map — enable "Maps JavaScript API" in Google Cloud
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key_here
